APP_NAME=基于多源金融数据的股票基金趋势分析与风险评估系统
APP_ENV=development
API_V1_PREFIX=/api/v1
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

MYSQL_DSN=mysql+pymysql://stock_user:stock_pass@127.0.0.1:3306/stock_analysis?charset=utf8mb4
REDIS_URL=redis://127.0.0.1:6379/0

QUOTE_CACHE_TTL_SECONDS=5
HISTORY_CACHE_TTL_SECONDS=1800
WS_PUSH_INTERVAL_SECONDS=5
SQL_ECHO=false
ENABLE_FIXTURE_FALLBACK=false
